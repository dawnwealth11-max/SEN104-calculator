<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_calculator"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- Display Area                                                   -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/displayContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg_display"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="20dp"
        android:paddingTop="36dp"
        app:layout_constraintBottom_toTopOf="@+id/scientificContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- History button top-right corner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="top|end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_history_toggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="History"
                android:src="@drawable/ic_history"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <!-- Expression Preview -->
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/text_secondary"
            android:textSize="22sp"
            android:maxLines="2"
            android:ellipsize="start"
            tools:text="sin(45) + 3 ^ 2" />

        <!-- Result -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="end"
            android:textColor="@color/text_primary"
            android:textSize="52sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="9.707" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- Scientific Panel (collapsible)                                 -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/scientificContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:background="@color/bg_display"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/keyboardContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Row 1: 2nd, sin, cos, tan, ^, (, ) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:weightSum="7">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_2nd"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="2nd"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sin"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="sin"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cos"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="cos"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tan"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="tan"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pow"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="xʸ"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_paren_open"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="("
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_paren_close"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text=")"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Row 2: ln, log, π, e, !, nPr, nCr -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:weightSum="7"
            android:layout_marginTop="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ln"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="ln"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_log"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="log"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pi"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="π"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_e"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="e"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_fact"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="n!"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_npr"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="nPr"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ncr"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="nCr"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- Main Keyboard                                                  -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/keyboardContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:paddingTop="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Utility row: SCI | DEG/RAD | C | ⌫ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sci_toggle"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="SCI"
                android:textColor="@color/btn_equal"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_angle_toggle"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="DEG"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="C"
                android:textColor="#FF5252"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="⌫"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <!-- Row: %, ÷, ×, - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_percent"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_action"
                app:rippleColor="@android:color/transparent"
                android:text="%"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_divide"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_operator"
                app:rippleColor="@android:color/transparent"
                android:text="÷"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_multiply"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_operator"
                app:rippleColor="@android:color/transparent"
                android:text="×"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_subtract"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_operator"
                app:rippleColor="@android:color/transparent"
                android:text="-"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Row: 7, 8, 9, + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_7"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="7"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_8"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="8"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_9"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="9"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_operator"
                app:rippleColor="@android:color/transparent"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Row: 4, 5, 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_4"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="4"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_5"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="5"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_6"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="6"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_subtract"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_operator"
                app:rippleColor="@android:color/transparent"
                android:text="-"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Row: 1, 2, 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_1"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="1"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_2"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="2"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_3"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="3"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_operator"
                app:rippleColor="@android:color/transparent"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Row: 00(hidden in SCI), 0, ., = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_double_zero"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="√"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_0"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dot"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_number"
                app:rippleColor="@android:color/transparent"
                android:text="."
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_equal"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:backgroundTint="@color/btn_equal"
                app:rippleColor="@android:color/transparent"
                android:text="="
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- History Overlay                                                -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/historyContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/bg_display"
        android:visibility="gone"
        android:elevation="12dp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="@+id/scientificContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="History"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_history"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="#FF5252"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_close_history"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ Close"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Scrollable history list -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/llHistoryItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
